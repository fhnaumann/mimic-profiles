# Pipeline configuration — copy to .env and adjust. Scripts read these as
# defaults; their CLI flags override. Load into a shell with:
#   set -a; source .env; set +a

# FHIR terminology server (Ontoserver) base URL. When unset, the terminology
# build scripts skip their upload step and check_icd_codes.py refuses to run.
ONTOSERVER_URL=https://velonto.dw.csiro.au/fhir

# Directory containing the raw ICD source distributions
# (2012_icd9/, 2016/ … 2019/ — layout in scripts/terminology-build/README.md,
# identity pinned in scripts/terminology-build/input-manifest.json)
ICD_SOURCE_DIR=/path/to/icd-sources

# Pathling Delta warehouse holding the full MIMIC-on-FHIR data (HPC node only)
MIMIC_WAREHOUSE=/path/to/spark_warehouse
